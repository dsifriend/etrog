{
	"$schema": "https://typedoc.org/schema.json",
	"entryPoints": [
		"packages/rdf/",
		"packages/core/",
		"packages/wordnet/",
		"packages/dbnary/",
		"packages/export-dict/",
		"packages/export-apple/"
	],
	"entryPointStrategy": "packages",
