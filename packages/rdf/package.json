{
	"name": "@etrog/rdf",
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target bun && tsc --emitDeclarationOnly --noEmit false",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "bunx @biomejs/biome check ./src",
		"format": "bunx @biomejs/biome format --write ./src"
	},
	"dependencies": {
		"@etrog/core": "workspace:*",
		"jsonld": "^9.0.0",
		"n3": "^2.0.3",
		"rdfxml-streaming-parser": "^3.2.0"
	},
	"devDependencies": {
		"@types/jsonld": "^1.5.15",
		"@types/n3": "^1.26.1",
		"bun-types": "^1.3.14"
	}
}
